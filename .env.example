# ─── FoundIt environment variables ───────────────────────────────
# Copy this file to `.env` (local) and set the same keys in your
# Vercel project settings (Production + Preview). Never commit `.env`.

# MongoDB Atlas connection string (M0 free cluster).
# Atlas → Database → Connect → Drivers. Include the DB name, e.g. /foundit
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/foundit?retryWrites=true&w=majority

# Secret used to sign JWT auth tokens. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated email domains allowed to register (SMVDU community gate).
ALLOWED_EMAIL_DOMAINS=smvdu.ac.in

# Comma-separated emails that should be granted the admin role on signup/seed.
ADMIN_EMAILS=

# Google Gemini API key (AI matching). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Cloudinary (image uploads — client-side unsigned upload).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# Brevo (transactional email for match/claim alerts). https://app.brevo.com
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@yourdomain.com
BREVO_SENDER_NAME=FoundIt SMVDU

# Public base URL of the deployed app (used in email links). No trailing slash.
CLIENT_URL=http://localhost:5173

# Local Express dev server port (not used on Vercel).
PORT=5000
